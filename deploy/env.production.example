# Rename to .env on the VPS (same directory as manage.py). Do not commit .env.

SECRET_KEY=replace-with-django-get-random-secret-key-output
DEBUG=False
ALLOWED_HOSTS=codecraften.com,www.codecraften.com
CSRF_TRUSTED_ORIGINS=https://codecraften.com,https://www.codecraften.com

# PostgreSQL (recommended on VPS)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=codecraften_db
DB_USER=codecraften_user
DB_PASSWORD=replace-with-strong-password
DB_HOST=localhost
DB_PORT=5432

# Optional: before SSL is live, temporarily use:
# CSRF_TRUSTED_ORIGINS=http://codecraften.com,http://www.codecraften.com
